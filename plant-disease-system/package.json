{
  "name": "plant-disease-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-all": "cd server && npm install && cd ../client && npm install",
    "start:server": "npm --prefix ./server start",
    "start:client": "npm --prefix ./client run dev",
    "dev": "concurrently \"npm --prefix ./server start\" \"npm --prefix ./client run dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}